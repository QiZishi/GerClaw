# ================================================================
# GerClaw MVP 环境变量示例
# 复制此文件为 .env.local 并填入真实密钥
# 密钥只能 .env 注入，禁止硬编码，禁止提交 .env 到 Git（铁律 7）
# ================================================================

# --- 主模型（OpenAI 兼容协议）---
# 主用 LLM 服务端点
NEXT_PUBLIC_PRIMARY_URL=
# 主用 LLM API Key
NEXT_PUBLIC_PRIMARY_API_KEY=
# 主用模型名称
NEXT_PUBLIC_PRIMARY_MODEL=qwen3.7-plus
# 主用模型协议：openai / dashscope / anthropic
NEXT_PUBLIC_PRIMARY_PROTOCOL=openai

# --- 备用模型 1（DashScope 兼容协议）---
NEXT_PUBLIC_BACKUP1_URL=
NEXT_PUBLIC_BACKUP1_API_KEY=
NEXT_PUBLIC_BACKUP1_MODEL=qwen-plus
NEXT_PUBLIC_BACKUP1_PROTOCOL=dashscope

# --- 备用模型 2（OpenAI 兼容协议）---
NEXT_PUBLIC_BACKUP2_URL=
NEXT_PUBLIC_BACKUP2_API_KEY=
NEXT_PUBLIC_BACKUP2_MODEL=claude-sonnet-4-20250514
NEXT_PUBLIC_BACKUP2_PROTOCOL=openai

# --- ASR 语音识别服务 ---
# ASR 服务端点（Mimo API）
NEXT_PUBLIC_ASR_URL=
# ASR API Key（Mimo API Key 共用）
NEXT_PUBLIC_ASR_API_KEY=
# ASR 模型名称
NEXT_PUBLIC_ASR_MODEL=mimo-v2.5-asr

# --- TTS 语音合成服务 ---
# TTS 服务端点（Mimo API，与 ASR 共用端点）
NEXT_PUBLIC_TTS_URL=
# TTS API Key（Mimo API Key 共用）
NEXT_PUBLIC_TTS_API_KEY=
# TTS 模型名称
NEXT_PUBLIC_TTS_MODEL=mimo-v2.5-tts
# TTS 语音角色
NEXT_PUBLIC_TTS_VOICE=冰糖

# --- 联网搜索 ---
# AnySearch API Key（主搜索）
NEXT_PUBLIC_ANYSEARCH_API_KEY=
# Tavily API Key（备搜索，AnySearch 失败时降级）
NEXT_PUBLIC_TAVILY_API_KEY=

# --- 应用配置 ---
NEXT_PUBLIC_APP_NAME=GerClaw
NEXT_PUBLIC_APP_VERSION=0.1.0
