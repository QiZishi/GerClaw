# ================================================================
# GerClaw 环境变量示例模板
# 复制此文件为 .env.local 并填入真实密钥
# 密钥只能 .env 注入，禁止硬编码，禁止提交 .env 到 Git（铁律 7）
# ================================================================

# --- 主用模型（OpenAI 兼容协议） ---
# 注意：API KEY 请使用不带 NEXT_PUBLIC_ 前缀的变量名（服务端安全使用）
# 系统会自动向后兼容：优先读 PRIMARY_API_KEY，没有则读 NEXT_PUBLIC_PRIMARY_API_KEY
NEXT_PUBLIC_PRIMARY_URL=https://your-llm-endpoint/v1
PRIMARY_API_KEY=sk-your-primary-api-key
# NEXT_PUBLIC_PRIMARY_API_KEY=sk-your-primary-api-key  # 旧配置兼容，不推荐
NEXT_PUBLIC_PRIMARY_MODEL=gpt-4o
NEXT_PUBLIC_PRIMARY_PROTOCOL=openai

# --- 备用模型 1 ---
NEXT_PUBLIC_BACKUP1_URL=
BACKUP1_API_KEY=
# NEXT_PUBLIC_BACKUP1_API_KEY=  # 旧配置兼容，不推荐
NEXT_PUBLIC_BACKUP1_MODEL=qwen-plus
NEXT_PUBLIC_BACKUP1_PROTOCOL=openai

# --- 备用模型 2 ---
NEXT_PUBLIC_BACKUP2_URL=
BACKUP2_API_KEY=
# NEXT_PUBLIC_BACKUP2_API_KEY=  # 旧配置兼容，不推荐
NEXT_PUBLIC_BACKUP2_MODEL=claude-sonnet-4-20250514
NEXT_PUBLIC_BACKUP2_PROTOCOL=anthropic

# --- Mimo ASR/TTS（仅 Next.js 服务端读取，严禁 NEXT_PUBLIC_ 前缀）---
MIMO_API_KEY=
MIMO_ASR_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_URL=https://api.xiaomimimo.com/v1
GERCLAW_MIMO_AUTH_HEADER=api-key
ASR_MODEL=mimo-v2.5-asr
TTS_MODEL=mimo-v2.5-tts
TTS_VOICE=冰糖
# 旧 NEXT_PUBLIC_ASR_* / NEXT_PUBLIC_TTS_* 配置仅在迁移期兼容，部署时请移除。

# --- 联网搜索 ---
# 搜索只允许服务端读取，禁止 NEXT_PUBLIC_ 前缀。
ANYSEARCH_URL=https://api.anysearch.com
ANYSEARCH_API_KEY=
TAVILY_URL=https://api.tavily.com
TAVILY_API_KEY=

# --- MinerU 文档解析（仅服务端读取） ---
MINERU_URL=https://mineru.net/api/v1/agent
MINERU_API_KEY=
MINERU_ALLOWED_HOSTS=mineru.net,mineru.oss-cn-shanghai.aliyuncs.com,oss-mineru.openxlab.org.cn,cdn-mineru.openxlab.org.cn

# --- 应用配置 ---
NEXT_PUBLIC_APP_NAME=GerClaw
NEXT_PUBLIC_APP_VERSION=0.1.0
