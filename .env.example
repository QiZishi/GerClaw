# GerClaw full-stack local development. Copy to .env and rotate every secret.
GERCLAW_APP_ENV=development
GERCLAW_API_IMAGE=gerclaw-api
GERCLAW_LOG_LEVEL=INFO
GERCLAW_DATABASE_URL=postgresql+asyncpg://gerclaw:local-postgres-only@postgres:5432/gerclaw
GERCLAW_DATABASE_POOL_SIZE=20
GERCLAW_DATABASE_MAX_OVERFLOW=20
GERCLAW_DATABASE_POOL_TIMEOUT_SECONDS=10
GERCLAW_REDIS_URL=redis://:local-redis-only@redis:6379/0
GERCLAW_REDIS_MAX_CONNECTIONS=100
GERCLAW_QDRANT_URL=http://qdrant:6333
GERCLAW_QDRANT_API_KEY=local-qdrant-only
GERCLAW_KNOWLEDGE_BASE_PATH=/knowledge-base
GERCLAW_RAG_COLLECTION_NAME=gerclaw_local_medical_v1
GERCLAW_RAG_EMBEDDING_DIMENSIONS=1024
GERCLAW_RAG_EMBEDDING_BATCH_SIZE=64
GERCLAW_RAG_EMBEDDING_CONCURRENCY=1
GERCLAW_RAG_EMBEDDING_TOKENS_PER_MINUTE=450000
GERCLAW_RAG_CHUNK_MIN_TOKENS=256
GERCLAW_RAG_CHUNK_TARGET_TOKENS=384
GERCLAW_RAG_CHUNK_MAX_TOKENS=512
GERCLAW_RAG_CHUNK_OVERLAP_TOKENS=64
GERCLAW_RAG_MAX_DOCUMENT_BYTES=8388608
GERCLAW_RAG_UPSERT_BATCH_SIZE=64
GERCLAW_RAG_RETRIEVAL_CANDIDATES=30
GERCLAW_RAG_RERANK_CANDIDATES=20
GERCLAW_RAG_MIN_RERANK_SCORE=0.05
GERCLAW_CORS_ORIGINS='["http://localhost:3000"]'
GERCLAW_AGENTSCOPE_REQUIRED_VERSION=2.0.4
GERCLAW_EXTERNAL_REQUEST_TIMEOUT_SECONDS=30
GERCLAW_MAX_REQUEST_BODY_BYTES=262144
GERCLAW_RATE_LIMIT_REQUESTS=100
GERCLAW_RATE_LIMIT_WINDOW_SECONDS=60
GERCLAW_MAX_EVENTS_PER_TRACE=10000
GERCLAW_AGENT_MAX_REACT_ITERATIONS=10
GERCLAW_AGENT_HISTORY_MESSAGES=40
GERCLAW_AGENT_EVIDENCE_TOP_K=5
GERCLAW_AGENT_MODEL_TIMEOUT_SECONDS=60
GERCLAW_AGENT_MODEL_MAX_OUTPUT_TOKENS=1024
GERCLAW_AGENT_MAX_OUTPUT_CHARACTERS=20000
GERCLAW_CHAT_SESSION_LEASE_TTL_SECONDS=300
GERCLAW_MEMORY_COLLECTION_NAME=gerclaw_user_memory_v1
GERCLAW_MEMORY_RETRIEVAL_TOP_K=5
GERCLAW_MEMORY_RETRIEVAL_CANDIDATES=20
GERCLAW_MEMORY_MIN_SCORE=0.2
GERCLAW_MEMORY_CONTEXT_BUDGET_RATIO=0.55
GERCLAW_MEMORY_EXTRACTION_MIN_CONFIDENCE=0.8
GERCLAW_MEMORY_MAX_FACTS_PER_TURN=12
GERCLAW_SEARCH_TIMEOUT_SECONDS=10
GERCLAW_SEARCH_MAX_RETRIES=1
GERCLAW_SEARCH_MAX_RESPONSE_BYTES=2097152
GERCLAW_SEARCH_MAX_CONTENT_CHARACTERS=50000
GERCLAW_SKILL_MAX_MARKDOWN_CHARACTERS=10000
GERCLAW_SKILL_MAX_ARCHIVE_BYTES=262144
GERCLAW_SKILL_MAX_LOADED=10
GERCLAW_SKILL_ALLOWED_TOOLS='["search_knowledge","web_search","search_memory"]'
GERCLAW_GUEST_TOKEN_TTL_SECONDS=3600
# Local development creates random persistent keys under this directory. Production
# must explicitly inject GERCLAW_AUTH_JWT_SECRET and GERCLAW_GUEST_IDENTITY_SECRET
# (each >=32 chars), plus a base64-encoded 32-byte GERCLAW_DATA_ENCRYPTION_KEY
# from a secret manager. Keep guest identity stable when rotating JWT signing keys.
GERCLAW_LOCAL_SECRET_DIR=~/.local/share/gerclaw/secrets
# GERCLAW_AUTH_JWT_SECRET=<secret-manager-value>
# GERCLAW_GUEST_IDENTITY_SECRET=<stable-secret-manager-value>
# GERCLAW_DATA_ENCRYPTION_KEY=<base64-encoded-32-byte-key>
GERCLAW_AUTH_JWT_ISSUER=gerclaw
GERCLAW_AUTH_JWT_AUDIENCE=gerclaw-api
GERCLAW_DATA_ENCRYPTION_KEY_ID=local-v1

# Agent models (server-only). Legacy NEXT_PUBLIC_* values are accepted temporarily
# for local migration, but production secrets must never be exposed to the browser.
AGENT_PRIMARY_URL=https://your-primary.example.com/v1
AGENT_PRIMARY_API_KEY=replace-me
AGENT_PRIMARY_MODEL=qwen3.7-plus
AGENT_PRIMARY_PROTOCOL=openai
AGENT_PRIMARY_PREFERENCE=primary
AGENT_BACKUP1_URL=https://your-backup1.example.com/v1
AGENT_BACKUP1_API_KEY=replace-me
AGENT_BACKUP1_MODEL=qwen-plus
AGENT_BACKUP1_PROTOCOL=dashscope
AGENT_BACKUP1_PREFERENCE=backup1
AGENT_BACKUP2_URL=https://your-backup2.example.com/v1
AGENT_BACKUP2_API_KEY=replace-me
AGENT_BACKUP2_MODEL=your-backup-model
AGENT_BACKUP2_PROTOCOL=openai
AGENT_BACKUP2_PREFERENCE=backup2

# Voice services. URLs are configurable because existing MiMo credentials may use
# a tenant-specific token-plan endpoint instead of the public endpoint.
MIMO_API_KEY=replace-me
# Token-plan credentials use Bearer auth. For the public endpoint, use
# https://api.xiaomimimo.com/v1 and set GERCLAW_MIMO_AUTH_HEADER=api-key.
MIMO_ASR_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_TTS_URL=https://token-plan-cn.xiaomimimo.com/v1
GERCLAW_MIMO_AUTH_HEADER=authorization
ASR_MODEL=mimo-v2.5-asr
TTS_MODEL=mimo-v2.5-tts
TTS_VOICE=冰糖

# Agentic RAG embedding and rerank.
SILICONFLOW_API_KEY=replace-me
SILICONFLOW_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Search and document parsing.
ANYSEARCH_URL=https://api.anysearch.com
ANYSEARCH_API_KEY=
TAVILY_URL=https://api.tavily.com
TAVILY_API_KEY=replace-me
MINERU_URL=https://mineru.net/api/v1/agent
# Agent 轻量接口当前无需 Token；若切换到需认证接口再配置。
MINERU_API_KEY=
MINERU_ALLOWED_HOSTS=mineru.net,mineru.oss-cn-shanghai.aliyuncs.com,oss-mineru.openxlab.org.cn,cdn-mineru.openxlab.org.cn

# Docker Compose host-side settings.
POSTGRES_USER=gerclaw
POSTGRES_PASSWORD=local-postgres-only
POSTGRES_DB=gerclaw
POSTGRES_TEST_DB=gerclaw_test
POSTGRES_PORT=5432
REDIS_PASSWORD=local-redis-only
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
API_PORT=8000
# Next.js server-only BFF target. Docker deployments should use http://api:8000.
GERCLAW_API_URL=http://127.0.0.1:8000
# The Next.js BFF signs pseudonymous visitor identities with the server-only
# GERCLAW_GUEST_IDENTITY_SECRET. Never expose it as NEXT_PUBLIC_*.
GERCLAW_KNOWLEDGE_BASE_HOST_PATH=../本地知识库/md
PYTHON_IMAGE=python:3.12-slim
