# GerClaw 唯一环境配置模板。复制为根目录 .env 后，只需填写标注为“密钥”的空值。

# 应用环境；本地使用 development，自动化测试使用 test，生产使用 production。
GERCLAW_APP_ENV=development
# 后端应用名称；用于日志与 OpenAPI 标识，通常无需修改。
GERCLAW_APP_NAME=GerClaw API
# 后端业务接口前缀；前后端已按该路径对接，通常无需修改。
GERCLAW_API_PREFIX=/api/v1
# Docker API 镜像名称；自建镜像仓库时改为完整镜像地址。
GERCLAW_API_IMAGE=gerclaw-api
# Docker Web 镜像名称；自建镜像仓库时改为完整镜像地址。
GERCLAW_WEB_IMAGE=gerclaw-web
# Docker 测试 API 镜像名称；仅运行容器化测试时使用。
GERCLAW_API_TEST_IMAGE=gerclaw-api-test
# 日志级别；可选 DEBUG、INFO、WARNING、ERROR、CRITICAL。
GERCLAW_LOG_LEVEL=INFO
# PostgreSQL 异步连接串；Docker 使用 postgres 主机名，本地启动器会自动换为 127.0.0.1。
GERCLAW_DATABASE_URL=postgresql+asyncpg://gerclaw:local-postgres-only@postgres:5432/gerclaw
# PostgreSQL 常驻连接池大小；按数据库连接上限和 API 副本数调整。
GERCLAW_DATABASE_POOL_SIZE=20
# PostgreSQL 连接池允许的临时溢出连接数。
GERCLAW_DATABASE_MAX_OVERFLOW=20
# 获取数据库连接的最长等待秒数。
GERCLAW_DATABASE_POOL_TIMEOUT_SECONDS=10
# Redis 连接串；Docker 使用 redis 主机名，本地启动器会自动换为 127.0.0.1。
GERCLAW_REDIS_URL=redis://:local-redis-only@redis:6379/0
# 单个 API 进程允许的 Redis 最大连接数。
GERCLAW_REDIS_MAX_CONNECTIONS=100
# Qdrant HTTP 地址；Docker 使用 qdrant 主机名，本地启动器会自动换为 127.0.0.1。
GERCLAW_QDRANT_URL=http://qdrant:6333
# Qdrant 本地访问口令；生产环境改为随机强口令，并与 Qdrant 服务保持一致。
GERCLAW_QDRANT_API_KEY=local-qdrant-only
# 容器内医学知识库路径；
GERCLAW_KNOWLEDGE_BASE_PATH=/knowledge-base
# 允许调用 API 的 Web 来源；多个地址按 JSON 数组填写。
GERCLAW_CORS_ORIGINS='["http://localhost:3000"]'
# AgentScope 运行时要求版本；升级依赖时同步核对兼容性。
GERCLAW_AGENTSCOPE_REQUIRED_VERSION=2.0.4
# readiness 检查结果缓存秒数；调试依赖状态时可设为 0。
GERCLAW_READINESS_CACHE_SECONDS=5
# 外部 HTTP 服务通用请求超时秒数。
GERCLAW_EXTERNAL_REQUEST_TIMEOUT_SECONDS=30
# Chat 图片等请求体总上限，单位字节；当前约 72 MiB。
GERCLAW_MAX_REQUEST_BODY_BYTES=75497472
# ASR 音频请求体上限，单位字节；当前约 10 MiB。
GERCLAW_MAX_VOICE_ASR_BODY_BYTES=10487808
# 单份 MinerU Markdown 的字符上限。
GERCLAW_DOCUMENT_MAX_MARKDOWN_CHARACTERS=1000000
# 当前对话所有解析文档合并后的字符上限；产品要求为 273k。
GERCLAW_DOCUMENT_CONTEXT_MAX_CHARACTERS=273000
# 五大处方完整模型链最长运行秒数。
GERCLAW_PRESCRIPTION_GENERATION_TIMEOUT_SECONDS=600
# 单个限流窗口允许的请求数。
GERCLAW_RATE_LIMIT_REQUESTS=100
# 限流窗口长度，单位秒。
GERCLAW_RATE_LIMIT_WINDOW_SECONDS=60
# 单条 Trace 最多保存的事件数。
GERCLAW_MAX_EVENTS_PER_TRACE=10000
# Agent 单次 ReAct 最多迭代次数。
GERCLAW_AGENT_MAX_REACT_ITERATIONS=6
# 注入模型的最近历史消息上限。
GERCLAW_AGENT_HISTORY_MESSAGES=40
# Agent 默认引用的证据条数上限。
GERCLAW_AGENT_EVIDENCE_TOP_K=5
# 每个候选模型单次调用超时秒数。
GERCLAW_AGENT_MODEL_TIMEOUT_SECONDS=180
# 模型最大输出 token；五大处方按 32768 配置。
GERCLAW_AGENT_MODEL_MAX_OUTPUT_TOKENS=32768
# 模型能力声明契约版本；变更图片、工具或结构输出能力时升级。
GERCLAW_AGENT_MODEL_CAPABILITY_VERSION=model-capabilities-v1
# 模型可见输出字符硬上限，与 32768 output token 配套。
GERCLAW_AGENT_MAX_OUTPUT_CHARACTERS=131072
# 同一会话生成任务的分布式 lease 有效期秒数。
GERCLAW_CHAT_SESSION_LEASE_TTL_SECONDS=300
# Qdrant 中长期 Memory 的 collection 名称。
GERCLAW_MEMORY_COLLECTION_NAME=gerclaw_user_memory_v1
# 每轮注入上下文的 Memory 条数。
GERCLAW_MEMORY_RETRIEVAL_TOP_K=5
# Memory 向量初筛候选数。
GERCLAW_MEMORY_RETRIEVAL_CANDIDATES=20
# Memory 最低相似度分数。
GERCLAW_MEMORY_MIN_SCORE=0.2
# Memory 最多占用上下文预算的比例。
GERCLAW_MEMORY_CONTEXT_BUDGET_RATIO=0.55
# 自动写入长期事实的最低置信度。
GERCLAW_MEMORY_EXTRACTION_MIN_CONFIDENCE=0.8
# 单轮最多写入的 Memory 事实数。
GERCLAW_MEMORY_MAX_FACTS_PER_TURN=12
# 联网搜索单次请求超时秒数。
GERCLAW_SEARCH_TIMEOUT_SECONDS=10
# 联网搜索失败后的最大重试次数。
GERCLAW_SEARCH_MAX_RETRIES=1
# 联网搜索响应体最大字节数。
GERCLAW_SEARCH_MAX_RESPONSE_BYTES=2097152
# 联网搜索正文清洗后的最大字符数。
GERCLAW_SEARCH_MAX_CONTENT_CHARACTERS=50000
# 单个 Skill Markdown 的最大字符数。
GERCLAW_SKILL_MAX_MARKDOWN_CHARACTERS=10000
# Skill ZIP 包最大字节数。
GERCLAW_SKILL_MAX_ARCHIVE_BYTES=262144
# 单个会话最多加载的 Skill 数量。
GERCLAW_SKILL_MAX_LOADED=10
# Skill 允许调用的工具清单；按 JSON 数组填写。
GERCLAW_SKILL_ALLOWED_TOOLS='["search_knowledge","web_search","search_memory"]'
# 游客访问令牌有效期秒数。
GERCLAW_GUEST_TOKEN_TTL_SECONDS=3600
# 容器内持久化本地密钥的目录；本地启动器会换为用户目录。
GERCLAW_LOCAL_SECRET_DIR=/app/workspaces/secrets
# JWT 签名密钥；至少 32 个随机字符，必须填写且不得提交。
GERCLAW_AUTH_JWT_SECRET=
# 游客身份 HMAC 密钥；至少 32 个随机字符，必须填写且保持稳定。
GERCLAW_GUEST_IDENTITY_SECRET=
# JWT issuer；只有与外部网关联动时才需修改。
GERCLAW_AUTH_JWT_ISSUER=gerclaw
# JWT audience；只有与外部网关联动时才需修改。
GERCLAW_AUTH_JWT_AUDIENCE=gerclaw-api
# 数据加密密钥；填写“32 随机字节的 Base64”，可用 openssl rand -base64 32 生成。
GERCLAW_DATA_ENCRYPTION_KEY=
# 数据加密密钥版本 ID；轮换密钥时同步升级并保留旧密钥解密能力。
GERCLAW_DATA_ENCRYPTION_KEY_ID=local-v1

# 医学知识向量 collection 名称；更换 embedding 维度时使用新名称。
GERCLAW_RAG_COLLECTION_NAME=gerclaw_local_medical_v1
# Embedding 向量维度；必须与所选模型实际输出一致。
GERCLAW_RAG_EMBEDDING_DIMENSIONS=1024
# Embedding 单批文段数；按供应商配额调整。
GERCLAW_RAG_EMBEDDING_BATCH_SIZE=64
# Embedding 并发批次数；遇到限流时降低。
GERCLAW_RAG_EMBEDDING_CONCURRENCY=1
# Embedding 每分钟 token 预算；按供应商套餐填写。
GERCLAW_RAG_EMBEDDING_TOKENS_PER_MINUTE=450000
# RAG 文段最小 token 数。
GERCLAW_RAG_CHUNK_MIN_TOKENS=256
# RAG 文段目标 token 数。
GERCLAW_RAG_CHUNK_TARGET_TOKENS=384
# RAG 文段最大 token 数。
GERCLAW_RAG_CHUNK_MAX_TOKENS=512
# 相邻 RAG 文段重叠 token 数。
GERCLAW_RAG_CHUNK_OVERLAP_TOKENS=64
# 单份知识库 Markdown 最大字节数。
GERCLAW_RAG_MAX_DOCUMENT_BYTES=8388608
# Qdrant 单次 upsert 文段数。
GERCLAW_RAG_UPSERT_BATCH_SIZE=64
# Hybrid Retrieval 初筛候选数。
GERCLAW_RAG_RETRIEVAL_CANDIDATES=30
# 送入 Rerank 的候选数。
GERCLAW_RAG_RERANK_CANDIDATES=30
# Rerank 最低相关性分数。
GERCLAW_RAG_MIN_RERANK_SCORE=0.05

# 主模型 OpenAI 兼容地址；
# 在https://bailian.console.aliyun.com/cn-beijing?tab=model#/model-market 中获取调用地址和 API Key，必须填写。
# 注：https://university.aliyun.com/?spm=a2c4g.11186623.0.0.664875b7jJElBm&scm=20140722.M_10513608._.V_1 进入该链接可以获得300元模型token调用抵用劵
AGENT_PRIMARY_URL=
# 主模型 API 密钥；从对应模型服务控制台获取，必须填写。
AGENT_PRIMARY_API_KEY=
# 主模型名称；
AGENT_PRIMARY_MODEL=qwen3.7-plus
# 主模型协议；可选 openai、dashscope、anthropic。
AGENT_PRIMARY_PROTOCOL=openai
# 主模型槽位标识；保持 primary。
AGENT_PRIMARY_PREFERENCE=primary
# 主模型是否支持图片输入；按模型真实能力填写。
AGENT_PRIMARY_SUPPORTS_IMAGE_INPUT=true
# 主模型是否支持 tool calling；按模型真实能力填写。
AGENT_PRIMARY_SUPPORTS_TOOL_CALLING=true
# 主模型是否支持结构化输出；按模型真实能力填写。
AGENT_PRIMARY_SUPPORTS_STRUCTURED_OUTPUT=true

# 备用模型一地址；主模型失败时使用。
AGENT_BACKUP1_URL=
# 备用模型一 API 密钥；从对应服务控制台获取，必须填写。
AGENT_BACKUP1_API_KEY=
# 备用模型一名称。
AGENT_BACKUP1_MODEL=qwen3.6-flash
# 备用模型一协议；可选 openai、dashscope、anthropic。
AGENT_BACKUP1_PROTOCOL=dashscope
# 备用模型一槽位标识；保持 backup1。
AGENT_BACKUP1_PREFERENCE=backup1
# 备用模型一是否支持图片输入。
AGENT_BACKUP1_SUPPORTS_IMAGE_INPUT=true
# 备用模型一是否支持 tool calling。
AGENT_BACKUP1_SUPPORTS_TOOL_CALLING=true
# 备用模型一是否支持结构化输出。
AGENT_BACKUP1_SUPPORTS_STRUCTURED_OUTPUT=true

# 备用模型二地址；前两套模型失败时使用。
# https://internlm.intern-ai.org.cn/api/document?lang=zh 访问该链接以获取intern-ai模型api和模型名称
AGENT_BACKUP2_URL=https://chat.intern-ai.org.cn/api/v1/
# 备用模型二 API 密钥；从对应服务控制台获取，必须填写。
AGENT_BACKUP2_API_KEY=
# 备用模型二名称。
AGENT_BACKUP2_MODEL=intern-s2-preview
# 备用模型二协议；可选 openai、dashscope、anthropic。
AGENT_BACKUP2_PROTOCOL=openai
# 备用模型二槽位标识；保持 backup2。
AGENT_BACKUP2_PREFERENCE=backup2
# 备用模型二是否支持图片输入。
AGENT_BACKUP2_SUPPORTS_IMAGE_INPUT=true
# 备用模型二是否支持 tool calling。
AGENT_BACKUP2_SUPPORTS_TOOL_CALLING=true
# 备用模型二是否支持结构化输出。
AGENT_BACKUP2_SUPPORTS_STRUCTURED_OUTPUT=true

# MiMo 语音服务密钥；从 MiMo 控制台获取，使用 ASR/TTS 时必须填写。
# 密钥获取链接：https://platform.xiaomimimo.com/console/balance
MIMO_API_KEY=
# MiMo ASR 地址；
MIMO_ASR_URL=https://api.xiaomimimo.com/v1
# MiMo TTS 地址；
MIMO_TTS_URL=https://api.xiaomimimo.com/v1
# MiMo 鉴权头模式；token-plan 使用 authorization，公开端点可用 api-key。
GERCLAW_MIMO_AUTH_HEADER=authorization
# ASR 模型名称
ASR_MODEL=mimo-v2.5-asr
# TTS 模型名称
TTS_MODEL=mimo-v2.5-tts
# TTS 音色名称；填写供应商支持的中文音色。
TTS_VOICE=冰糖
# 语音适配器能力契约版本。
GERCLAW_VOICE_CAPABILITY_VERSION=voice-capabilities-v1
# 语音适配器是否支持流式 ASR。
GERCLAW_VOICE_SUPPORTS_STREAMING_ASR=true
# 语音适配器是否支持 PCM16 TTS 音频。
GERCLAW_VOICE_SUPPORTS_PCM16_TTS=true

# SiliconFlow API 密钥；Embedding 与 Rerank 共用，必须填写。
# 密钥获取链接：https://cloud.siliconflow.cn/me/models
SILICONFLOW_API_KEY=
# SiliconFlow OpenAI 兼容服务地址。
SILICONFLOW_URL=https://api.siliconflow.cn/v1
# Embedding 模型名称；维度必须匹配 GERCLAW_RAG_EMBEDDING_DIMENSIONS。
EMBEDDING_MODEL=BAAI/bge-m3
# Rerank 模型名称；需返回 relevance score。
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RAG Provider 能力契约版本。
GERCLAW_RAG_CAPABILITY_VERSION=rag-capabilities-v1
# Embedding 服务是否支持批量输入。
GERCLAW_EMBEDDING_SUPPORTS_BATCH=true
# Rerank 服务是否返回相关性分数。
GERCLAW_RERANK_SUPPORTS_RELEVANCE_SCORES=true

# AnySearch 服务地址；作为首选联网搜索。
# 密钥获取链接：https://www.anysearch.com/home
ANYSEARCH_URL=https://api.anysearch.com
# AnySearch 服务密钥；在 AnySearch 控制台获取，启用该服务时填写。
ANYSEARCH_API_KEY=

# Tavily 服务地址；作为联网搜索备用。
# 密钥获取链接：https://www.tavily.com/
TAVILY_URL=https://api.tavily.com
# Tavily 服务密钥；在 Tavily 控制台获取，启用备用搜索时填写。
TAVILY_API_KEY=
# 搜索适配器能力契约版本。
GERCLAW_SEARCH_CAPABILITY_VERSION=search-capabilities-v1
# AnySearch 是否返回结构化结果。
GERCLAW_ANYSEARCH_SUPPORTS_STRUCTURED_RESULTS=true
# Tavily 是否返回结构化结果。
GERCLAW_TAVILY_SUPPORTS_STRUCTURED_RESULTS=true

# MinerU 解析接口地址；轻量 Agent 接口使用此默认值。
# 密钥获取链接：https://mineru.net/apiManage/docs
MINERU_URL=https://mineru.net/api/v1/agent
# MinerU 密钥；当前轻量接口可留空，切换到需认证接口时从 MinerU 获取并填写。
MINERU_API_KEY=
# MinerU 可访问主机白名单；加入解析 API、签名上传及 Markdown 下载域名。
MINERU_ALLOWED_HOSTS=mineru.net,mineru.oss-cn-shanghai.aliyuncs.com,oss-mineru.openxlab.org.cn,cdn-mineru.openxlab.org.cn
# MinerU 适配器能力契约版本。
GERCLAW_MINERU_CAPABILITY_VERSION=mineru-capabilities-v1
# MinerU 是否支持异步解析任务。
GERCLAW_MINERU_SUPPORTS_ASYNC_PARSE=true
# MinerU 是否支持导出 Markdown。
GERCLAW_MINERU_SUPPORTS_MARKDOWN_EXPORT=true

# PostgreSQL 用户名；需与连接串中的用户名一致。
POSTGRES_USER=gerclaw
# PostgreSQL 本地开发密码；生产部署改为随机强密码并同步连接串。
POSTGRES_PASSWORD=local-postgres-only
# PostgreSQL 主数据库名称。
POSTGRES_DB=gerclaw
# PostgreSQL 隔离测试数据库名称。
POSTGRES_TEST_DB=gerclaw_test
# 宿主机 PostgreSQL 端口；本地源码模式连接该端口。
POSTGRES_PORT=5432
# Redis 本地开发密码；生产部署改为随机强密码并同步连接串。
REDIS_PASSWORD=local-redis-only
# 宿主机 Redis 端口。
REDIS_PORT=6379
# 宿主机 Qdrant HTTP 端口。
QDRANT_HTTP_PORT=6333
# 宿主机 Qdrant gRPC 端口。
QDRANT_GRPC_PORT=6334
# 宿主机 API 端口。
API_PORT=8000
# 宿主机 Web 端口。
WEB_PORT=3000
# 构建 Web 镜像使用的 Node 基础镜像。
NODE_IMAGE=public.ecr.aws/docker/library/node:22-alpine
# npm 安装依赖使用的 registry；可改为官方 https://registry.npmjs.org。
NPM_REGISTRY=https://registry.npmmirror.com
# 浏览器标题中展示的产品名称；该变量允许进入前端 bundle。
NEXT_PUBLIC_APP_NAME=GerClaw
# 浏览器展示的产品版本；该变量允许进入前端 bundle。
NEXT_PUBLIC_APP_VERSION=1.0.0
# Next.js BFF 的 API 地址；Docker 使用 api 主机名，本地启动器自动换为 127.0.0.1。
GERCLAW_API_URL=http://api:8000
# 宿主机外挂医学知识库目录；保持“主题目录/Markdown”结构。
GERCLAW_KNOWLEDGE_BASE_HOST_PATH=./knowledge-base/md
# 构建 API 镜像使用的 Python 基础镜像。
PYTHON_IMAGE=python:3.12-slim

# 测试 PostgreSQL 连接串；仅容器化集成测试使用。
GERCLAW_TEST_DATABASE_URL=postgresql+asyncpg://gerclaw:local-postgres-only@postgres:5432/gerclaw_test
# 测试 Redis 连接串；使用独立逻辑库 15。
GERCLAW_TEST_REDIS_URL=redis://:local-redis-only@redis:6379/15
# 测试 Qdrant 地址。
GERCLAW_TEST_QDRANT_URL=http://qdrant:6333
# 测试 Qdrant 口令；需与 GERCLAW_QDRANT_API_KEY 一致。
GERCLAW_TEST_QDRANT_API_KEY=local-qdrant-only
# 测试容器内知识库路径。
GERCLAW_TEST_KNOWLEDGE_BASE_PATH=/knowledge-base
# 测试 Memory collection 名称，必须与生产名称隔离。
GERCLAW_TEST_MEMORY_COLLECTION_NAME=gerclaw_user_memory_test_v1
# 是否运行真实 PostgreSQL、Redis、Qdrant 集成测试；1 表示启用。
GERCLAW_RUN_INTEGRATION=1
# 是否调用会产生真实费用的外部 Provider 测试；默认 0，需要时显式改为 1。
GERCLAW_RUN_EXTERNAL=0
# 是否运行会创建并清理隔离卷的 Docker smoke；默认 0，需要时显式改为 1。
GERCLAW_RUN_DOCKER_SMOKE=0
# Docker smoke 使用的隔离 API 端口。
GERCLAW_DOCKER_SMOKE_API_PORT=18080
# Docker smoke 使用的隔离 Web 端口。
GERCLAW_DOCKER_SMOKE_WEB_PORT=13000
# 浏览器端到端测试访问地址；只允许本机 HTTP 地址。
GERCLAW_E2E_BASE_URL=http://127.0.0.1:3000
